# EditorConfig — https://editorconfig.org
# Keeps formatting consistent across editors and OSes.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown uses two trailing spaces as a line break — preserve them.
[*.md]
trim_trailing_whitespace = false

# Makefiles require real tabs.
[Makefile]
indent_style = tab

# Batch / shell scripts follow the platform's expected line endings.
[*.{bat,cmd}]
end_of_line = crlf

[*.sh]
end_of_line = lf

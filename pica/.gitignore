# ----------------------------------------------------------------------------
# Pica — .gitignore
# ----------------------------------------------------------------------------
# Philosophy: nothing secret, nothing machine-generated, nothing user-specific
# should ever end up in version control. When in doubt, ignore it.
# ----------------------------------------------------------------------------

# Runtime data — created by the server on first run.
# Contains encrypted employee records, pictures, punches, and leaves.
# NEVER commit this directory.
/data/
/backups/

# Runtime configuration — may contain KDF salt, verifier, server secret.
# Only config.json.example is tracked.
/config.json

# Passphrase / key material — never commit under any circumstance.
*.key
*.pem
*.p12
.passphrase
secrets/

# Node.js artifacts.
# Pica has zero npm dependencies on purpose; these rules exist so an accidental
# `npm install` doesn't pollute the repo.
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/
.yarn/

# Environment files
.env
.env.local
.env.*.local

# Logs
logs/
*.log

# OS artifacts
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace

# Build / temp artifacts (none expected — this is defensive)
dist/
build/
tmp/
temp/
.cache/

# Coverage / test output
coverage/
.nyc_output/

{
  "host": "127.0.0.1",
  "port": 8080,
  "dataDir": "./data",
  "backupDir": "./backups",
  "maxBodyBytes": 5242880,
  "attachmentMaxBytes": 6291456,
  "logLevel": "info",

  "_mail_help": [
    "The 'mail' block below is OPTIONAL and entirely operator-managed.",
    "The server never writes or auto-populates it.",
    "",
    "To enable outgoing mail, add the block with enabled:true and fill in all fields.",
    "Leave the block absent (or set enabled:false) to run Pica without mail notifications.",
    "",
    "Gmail / Google Workspace — recommended setup:",
    "  1. Enable 2-Step Verification on the sending account.",
    "  2. Create an App Password (Google Account → Security → App Passwords).",
    "  3. Use the App Password as 'pass' — NOT your regular account password.",
    "  4. Use a dedicated send-only account (e.g. notifications@yourco.com).",
    "",
    "Port / TLS options:",
    "  port 465 + secure:true  — Implicit TLS (recommended, default).",
    "  port 587 + secure:false — STARTTLS.  Most providers support both.",
    "",
    "Security note:",
    "  'pass' is stored in plaintext in this file.",
    "  Use a dedicated send-only account with an App Password, not your main credential.",
    "  config.json is gitignored and is NOT included in Pica backups — keep it safe separately."
  ],

  "mail": {
    "enabled": false,
    "host": "smtp.gmail.com",
    "port": 465,
    "secure": true,
    "user": "notifications@yourco.com",
    "pass": "<gmail-app-password>",
    "from": "Pica <notifications@yourco.com>"
  },

  "_security_help": [
    "The 'security' block below is written automatically by the server on first run",
    "and on the legacy-to-envelope migration. DO NOT hand-edit it.",
    "",
    "v2 envelope shape:",
    "  version: 2",
    "  wraps.passphrase — data key (DEK) wrapped by a key derived from the passphrase.",
    "    kdf.algorithm : 'scrypt'",
    "    kdf.salt      : hex string",
    "    kdf.cost      : 131072",
    "    kdf.blockSize : 8",
    "    kdf.parallelization : 1",
    "    wrapped       : base64 — the wrapped DEK; GCM auth tag acts as the verifier",
    "                    (there is NO separate 'verifier' field in v2).",
    "  wraps.recovery (optional) — same shape as wraps.passphrase, plus",
    "    createdAt     : ISO 8601 timestamp.",
    "    Present only after the operator generates a recovery code in Settings → Security.",
    "",
    "Legacy v1 installs (security.kdf + security.verifier) are migrated to v2",
    "automatically on next server start. No data is re-encrypted during migration.",
    "",
    "WARNING: losing config.json makes all encrypted data unrecoverable.",
    "The wrapped keys live here and are intentionally NOT restored from backups.",
    "DO NOT copy a 'security' block into config.json — the server writes it automatically on first run."
  ]
}
